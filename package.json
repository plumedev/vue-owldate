{
  "name": "vue-owldate",
  "version": "0.2.8",
  "description": "A lightweight and customizable date range picker component for Vue 3",
  "keywords": [
    "vue",
    "vue3",
    "datepicker",
    "date-range",
    "date-range-picker",
    "slider",
    "component",
    "typescript",
    "scss"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "./dist/vue-owldate.umd.cjs",
  "module": "./dist/vue-owldate.js",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/vue-owldate.js",
      "require": "./dist/vue-owldate.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "prebuild": "node -e \"const fs = require('fs'); if (fs.existsSync('dist')) fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run prebuild && cross-env BUILD_LIB=true vue-tsc --noEmit && cross-env BUILD_LIB=true vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "cross-env": "^10.1.0",
    "sass": "^1.98.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.4.0",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1"
  }
}
