{
  "name": "vue-owldate",
  "version": "0.1.0",
  "description": "A lightweight and customizable date range picker component for Vue 3",
  "keywords": [
    "vue",
    "vue3",
    "datepicker",
    "date-range",
    "date-range-picker",
    "slider",
    "component",
    "typescript",
    "scss"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "./dist/vue-owldate.umd.cjs",
  "module": "./dist/vue-owldate.js",
  "exports": {
    ".": {
      "import": "./dist/vue-owldate.js",
      "require": "./dist/vue-owldate.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "cross-env BUILD_LIB=true vue-tsc --noEmit && cross-env BUILD_LIB=true vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "cross-env": "^10.1.0",
    "sass": "^1.98.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1"
  }
}
